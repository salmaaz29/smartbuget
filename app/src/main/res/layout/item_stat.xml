<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Icône -->
            <TextView
                android:id="@+id/tvStatIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:textSize="22sp"
                android:background="@drawable/circle_background"
                android:text="🍔"/>

            <!-- Nom catégorie -->
            <TextView
                android:id="@+id/tvStatCategoryName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Alimentation"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#212121"/>

            <!-- Montant -->
            <TextView
                android:id="@+id/tvStatAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="450.00 MAD"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

        </LinearLayout>

        <!-- Ligne 2 : barre + pourcentage -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="36"
                android:progressTint="#6200EE"/>

            <TextView
                android:id="@+id/tvStatPercentage"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="36%"
                android:textSize="13sp"
                android:textColor="#6200EE"
                android:gravity="end"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>